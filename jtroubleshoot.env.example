# jtroubleshoot AI environment template
#
# You only need this file if the selected provider needs secrets or connection
# settings that are not already present in your shell environment.
# Start with:
#   ./jtroubleshoot status
#
# Provider and model selection belong in config.json or on the CLI:
#   ./jtroubleshoot config set provider <provider-id>
#   ./jtroubleshoot config set model <name>
#
# Packaged bundles include this file as `conf/jtroubleshoot.env`. Uncomment only
# the provider section you actually use.


# ------------------------------------------------------------------------------
# Shared runtime options
# ------------------------------------------------------------------------------
#
# Optional: override the saved report bundle directory.
# ANALYSIS_REPORT_DIR=reports
#
# Optional: override the config.json path.
# JTROUBLESHOOT_CONFIG_FILE=/absolute/path/to/config.json
#
# Optional: point the dotenv loader at another env file.
# ENV_FILE=/absolute/path/to/jtroubleshoot.env
#


# ------------------------------------------------------------------------------
# OCI Generative AI
# ------------------------------------------------------------------------------
#
# OCI auth and profile details are read from your OCI CLI or SDK config,
# typically `~/.oci/config`.
#
# OCI_COMPARTMENT_ID=
#
# Optional only if you need a non-default OCI profile:
# OCI_PROFILE=


# ------------------------------------------------------------------------------
# Ollama
# ------------------------------------------------------------------------------
#
# No env variables are normally required for the default local Ollama setup.


# ------------------------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------------------------
#
# OPENAI_API_KEY=


# ------------------------------------------------------------------------------
# Anthropic
# ------------------------------------------------------------------------------
#
# ANTHROPIC_API_KEY=


# ------------------------------------------------------------------------------
# Google AI Gemini
# ------------------------------------------------------------------------------
#
# GOOGLE_AI_GEMINI_API_KEY=


# ------------------------------------------------------------------------------
# Mistral AI
# ------------------------------------------------------------------------------
#
# MISTRAL_AI_API_KEY=


# ------------------------------------------------------------------------------
# Azure OpenAI
# ------------------------------------------------------------------------------
#
# Set the Azure deployment with `config.json` or `--model`.
#
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=


# ------------------------------------------------------------------------------
# xAI
# ------------------------------------------------------------------------------
#
# Set the model with `config.json` or `--model`.
#
# XAI_API_KEY=


# ------------------------------------------------------------------------------
# Groq
# ------------------------------------------------------------------------------
#
# GROQ_API_KEY=


# ------------------------------------------------------------------------------
# OpenRouter
# ------------------------------------------------------------------------------
#
# Set the routed model with `config.json` or `--model`.
#
# OPENROUTER_API_KEY=


# ------------------------------------------------------------------------------
# Together AI
# ------------------------------------------------------------------------------
#
# Set the model with `config.json` or `--model`.
#
# TOGETHER_API_KEY=


# ------------------------------------------------------------------------------
# Fireworks AI
# ------------------------------------------------------------------------------
#
# Set the model with `config.json` or `--model`.
#
# FIREWORKS_API_KEY=


# ------------------------------------------------------------------------------
# Generic OpenAI-compatible endpoint
# ------------------------------------------------------------------------------
#
# Set the model with `config.json` or `--model`.
#
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
#
# Some gateways also require:
# OPENAI_COMPATIBLE_API_KEY=
